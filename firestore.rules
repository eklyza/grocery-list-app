rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /lists/{listId} {
      // Any authenticated user can read and write lists
      allow read, update: if request.auth != null;

      // Any authenticated user can create a list, as long as they are the owner
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;

      // Only the owner can delete the list
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      // Any authenticated user can read or write items
      match /items/{itemId} {
        allow read, write: if request.auth != null;
      }
    }

    match /invitations/{invitationId} {
      // The invited user can see invitations addressed to their email.
      // List members can see all invitations for their list (for the Invite screen).
      allow read: if request.auth != null && (
        resource.data.invitedEmail == request.auth.token.email
        || request.auth.uid in get(/databases/$(database)/documents/lists/$(resource.data.listId)).data.members
      );

      // A list member can create an invitation for their list
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.invitedBy
        && request.auth.uid in get(/databases/$(database)/documents/lists/$(request.resource.data.listId)).data.members
        && request.resource.data.status == 'pending';

      // Only the invited user can update the invitation status (accept or decline)
      allow update: if request.auth != null
        && resource.data.invitedEmail == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['accepted', 'declined'];
    }
  }
}
